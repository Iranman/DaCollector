# Copy this file to .env before running `docker compose up -d --build`.

PUID=1000
PGID=1000
UMASK=002
TZ=Etc/UTC
DACOLLECTOR_PORT=8111
DACOLLECTOR_IMAGE_TAG=latest

# Plex target settings. Use host.docker.internal when Plex runs on the Docker host.
PLEX_TARGET_BASE_URL=http://host.docker.internal:32400
PLEX_TARGET_SECTION_KEY=
PLEX_TARGET_TOKEN=

# Provider settings.
TMDB_API_KEY=
IMDB_DATASET_PATH=
IMDB_CACHE_EXPIRATION_DAYS=7
TVDB_API_KEY=
TVDB_PIN=
TVDB_CACHE_EXPIRATION_DAYS=7

# Local build metadata.
DACOLLECTOR_DOCKERFILE=Dockerfile
DACOLLECTOR_BUILD_VERSION=0.0.0-local
DACOLLECTOR_BUILD_CHANNEL=local
DACOLLECTOR_BUILD_COMMIT=local
DACOLLECTOR_BUILD_TAG=local
DACOLLECTOR_BUILD_DATE=local
