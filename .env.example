# DaCollector — configuration template
#
# HOW TO USE
#   cp .env.example .env
#   nano .env            # fill in your values
#   docker compose up -d
#
# Lines starting with # are comments and are ignored.
# Remove the # at the start of a line to enable that setting.

# ── Container identity ────────────────────────────────────────────────────────
# UID and GID the server process runs as inside the container.
# Set these to the owner of your media folders so the container can read them.
# To find the right values on Linux: id <your-media-user>
PUID=1000
PGID=1000
UMASK=002

# Timezone. Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Etc/UTC

# ── Plex ─────────────────────────────────────────────────────────────────────
# URL of your Plex Media Server.
# - Same machine as Docker:  http://host.docker.internal:32400
# - Different machine on LAN: http://192.168.1.50:32400
PLEX_TARGET_BASE_URL=http://host.docker.internal:32400

# Plex API token.
# Find it in Plex Web: open any item → three-dot menu → Get Info,
# then look at the URL bar for X-Plex-Token=<value>.
PLEX_TARGET_TOKEN=

# Numeric library section key.
# Get it from: http://<plex-host>:32400/library/sections?X-Plex-Token=<token>
# The <key> attribute on each <Directory> element is the value you need.
PLEX_TARGET_SECTION_KEY=

# ── TMDB ─────────────────────────────────────────────────────────────────────
# Free v3 API key from https://www.themoviedb.org/settings/api
# Required for tmdb_collection, tmdb_show, and tmdb_movie builders.
TMDB_API_KEY=

# ── TVDB ─────────────────────────────────────────────────────────────────────
# API key from https://thetvdb.com/dashboard/account/apikeys
# Subscriber PIN is optional — leave blank if you do not have one.
TVDB_API_KEY=
TVDB_PIN=

# ── IMDb ─────────────────────────────────────────────────────────────────────
# IMDb builders read local dataset files — no API key needed.
# 1. Download title.basics.tsv.gz from https://datasets.imdbws.com/
# 2. Unpack it into a folder on your server.
# 3. Set IMDB_DATASET_PATH to that folder's host path.
# 4. Uncomment the IMDb volume line in docker-compose.yml.
# Leave blank to disable IMDb builders.
IMDB_DATASET_PATH=

# ── Port ─────────────────────────────────────────────────────────────────────
# Host port for the Web UI and API.  Change only if 38111 is already in use.
DACOLLECTOR_PORT=38111

# ── Media library paths ───────────────────────────────────────────────────────
# Host paths to your media folders.
# After setting these, uncomment the matching volume lines in docker-compose.yml,
# then add the /media/... container paths as Managed Folders inside DaCollector.
#MEDIA_MOVIES=/mnt/media/movies
#MEDIA_TV=/mnt/media/tv

# ── Advanced ─────────────────────────────────────────────────────────────────
# Set to true on TrueNAS/ZFS or ACL-managed datasets to skip recursive chown at
# startup. Without this, a first-boot ownership repair can take several minutes
# on a large ZFS pool. See docs for details.
SKIP_CHOWN=false
